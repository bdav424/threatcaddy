# Database
DATABASE_URL=postgres://tc:tc@db:5432/threatcaddy

# Server
PORT=3001
ADMIN_PORT=3002
FILE_STORAGE_PATH=/data/files

# CORS — comma-separated origins (default: * allows all)
ALLOWED_ORIGINS=https://your-app.example.com

# JWT Ed25519 keys (required)
# Generate with:
#   openssl genpkey -algorithm Ed25519 -out private.pem
#   openssl pkey -in private.pem -pubout -out public.pem
# Then set as single-line values (replace newlines with \n)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Admin panel secret (optional — auto-generated on first launch if not set)
ADMIN_SECRET=

# Trust proxy headers (X-Forwarded-For) for rate limiting
# Set to 1 only when running behind a reverse proxy (nginx, Cloudflare, etc.)
TRUST_PROXY=0

# LLM API keys (optional — enable AI features)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# Local OpenAI-compatible endpoint (Ollama, LM Studio, vLLM, or everybody_llmbo Codex REST bridge)
# For everybody_llmbo launched on loopback:
#   LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434
#   LOCAL_LLM_MODEL=gpt-5.4
#   LOCAL_LLM_API_KEY=codex-local-dev
LOCAL_LLM_ENDPOINT=
LOCAL_LLM_MODEL=
LOCAL_LLM_API_KEY=
