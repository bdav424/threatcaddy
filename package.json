{
  "name": "threatcaddy",
  "description": "ThreatCaddy — Threat Investigation Workspace. Notes, IOCs, Timelines & Graphs. No server. No tracking.",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.29.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:single": "tsc -b && vite build --config vite.config.single.ts",
    "copy:standalone": "node scripts/copy-standalone-artifacts.mjs --dist",
    "update:standalone": "pnpm build:single && node scripts/copy-standalone-artifacts.mjs --workspace",
    "standard:standalone": "pnpm update:standalone",
    "smoke:standalone": "node scripts/assistantcaddy-standalone-smoke.mjs",
    "checkpoint:assistantcaddy": "node scripts/assistantcaddy-rollout-checkpoint.mjs",
    "desktop:dev:renderer": "vite --host 127.0.0.1 --port 4173",
    "desktop:dev:main": "dotenv -e desktop/.env.desktop -- cross-env TC_DESKTOP_DEV_URL=http://127.0.0.1:4173 electron ./desktop/main.mjs",
    "desktop:start": "dotenv -e desktop/.env.desktop -- electron ./desktop/main.mjs",
    "desktop:package": "pnpm build && electron-builder --dir",
    "desktop:dist": "pnpm build && electron-builder",
    "desktop:dist:win": "pnpm build && electron-builder --win",
    "desktop:dist:mac": "pnpm build && electron-builder --mac",
    "desktop:dist:linux": "pnpm build && electron-builder --linux",
    "mobile:sync": "pnpm build && cap sync",
    "mobile:android": "pnpm build && cap sync android",
    "mobile:android:open": "cap open android",
    "mobile:ios": "pnpm build && cap sync ios",
    "mobile:ios:open": "cap open ios",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:extension": "cd extension && npm run build",
    "build:extension:chrome": "cd extension && npm run build:chrome",
    "build:extension:firefox": "cd extension && npm run build:firefox",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "translate": "node scripts/translate-i18n.mjs",
    "check:caddyai-bridges": "node scripts/check-caddyai-local-bridges.mjs",
    "integration-proxy": "node scripts/integration-proxy.mjs",
    "translate:dry": "node scripts/translate-i18n.mjs --dry-run",
    "translate:sync": "node scripts/translate-i18n.mjs --sync",
    "translate:sync:dry": "node scripts/translate-i18n.mjs --sync --dry-run",
    "deploy": "pnpm build && pnpm build:single && pnpm copy:standalone && touch dist/.nojekyll && npx gh-pages -d dist --dotfiles -m \"Deploy $(git rev-parse --short HEAD)\""
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@excalidraw/excalidraw": "^0.18.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@types/nunjucks": "^3.2.6",
    "cytoscape": "^3.33.1",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dexie": "^4.3.0",
    "diff-match-patch": "^1.0.5",
    "dompurify": "^3.4.0",
    "highlight.js": "^11.11.1",
    "i18next": "^26.0.3",
    "i18next-http-backend": "^3.0.4",
    "imapflow": "^1.4.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "mailparser": "^3.9.11",
    "marked": "^17.0.3",
    "minisearch": "^7.2.0",
    "nanoid": "^5.1.6",
    "nodemailer": "^9.0.1",
    "nunjucks": "^3.2.4",
    "pako": "^2.1.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.2",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "react-router-dom": "^7.13.0",
    "react-virtuoso": "^4.18.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff-match-patch": "^1.0.36",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/pako": "^2.0.4",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "electron": "^37.3.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^0.21.2",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "io.threatcaddy.app",
    "productName": "ThreatCaddy",
    "copyright": "Copyright © 2026 ThreatCaddy",
    "directories": {
      "output": "dist-desktop",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "desktop/main.mjs"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ThreatCaddy"
    }
  }
}
