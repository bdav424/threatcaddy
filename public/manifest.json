{
  "name": "ThreatCaddy",
  "short_name": "ThreatCaddy",
  "description": "Threat Investigation Workspace. Notes, IOCs, Timelines & Graphs. No server. No tracking.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "any",
  "categories": ["productivity", "security"],
  "theme_color": "#030712",
  "background_color": "#030712",
  "icons": [
    {
      "src": "logo.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "New Investigation",
      "short_name": "New",
      "description": "Create a new threat investigation",
      "url": "/?action=new-investigation",
      "icons": [{ "src": "logo.svg", "sizes": "any" }]
    },
    {
      "name": "Quick Capture",
      "short_name": "Capture",
      "description": "Save a quick note or indicator to the active investigation",
      "url": "/?action=capture",
      "icons": [{ "src": "logo.svg", "sizes": "any" }]
    }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "share_title",
      "text": "share_text",
      "url": "share_url"
    }
  },
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/markdown": [".md", ".markdown", ".mdown", ".mkd"],
        "text/plain": [".txt"]
      }
    }
  ]
}
